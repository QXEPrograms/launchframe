# ─── Discord ─────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Application (Client) ID
CLIENT_ID=your_client_id_here

# Your Discord User ID — ONLY this user can run bot commands
OWNER_ID=your_discord_user_id_here

# Guild (server) ID for instant command deployment during development
# Leave empty for global deployment (takes ~1 hour to propagate)
GUILD_ID=your_guild_id_here

# ─── Channel IDs (all optional but recommended) ───────────
WELCOME_CHANNEL_ID=channel_id_for_welcome_messages
MOD_LOG_CHANNEL_ID=channel_id_for_moderation_logs
ANNOUNCEMENT_CHANNEL_ID=default_announcement_channel_id

# ─── Tickets (set automatically via /ticketpanel) ─────────
# These are saved to data/tickets.json when you run /ticketpanel.
# Listing them here is optional — just for reference.
# TICKET_CATEGORY_ID=category_id_for_ticket_channels
# TICKET_SUPPORT_ROLE_ID=role_that_can_see_all_tickets

# ─── GitHub (for LaunchFrame status command) ──────────────
# Optional: add a token to avoid API rate limits (60 req/hr unauthenticated → 5000/hr with token)
GITHUB_TOKEN=optional_github_personal_access_token
GITHUB_REPO=qxeprograms/launchframe
