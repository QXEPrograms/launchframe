# Discord webhook URL — paste your Discord channel webhook here
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Exchange (binance, bybit, coinbase, kraken, etc.)
EXCHANGE=binance

# Trading symbol — use exchange format
# Crypto:  BTC/USDT, ETH/USDT, SOL/USDT
# Futures: BTC/USDT:USDT  (perpetual)
TRADING_SYMBOL=BTC/USDT

# LVN sensitivity — lower = stricter (0.2-0.5 range)
LVN_THRESHOLD=0.35

# Stop loss as % from LVN entry (0.003 = 0.3%)
STOP_LOSS_PCT=0.003

# Minimum R:R ratio to send a signal (1.5 recommended)
MIN_RR_RATIO=1.5

# How often to scan for setups (seconds). 60 = every 1-min candle close
SCAN_INTERVAL=60

# Send hourly bias/level update to Discord (true/false)
HOURLY_STATUS=true
